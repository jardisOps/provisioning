# =============================================================================
# Provisioning — INWX DNS Provider
# =============================================================================
#
# Kopiere diese Datei nach .env.inwx in dein Projektverzeichnis.
#

# --- Provisioning ---
DNS_PROVIDER=inwx

# --- API ---
INWX_USER=<username>
# INWX_PASSWORD=secret(base64encryptedvalue)
INWX_PASSWORD=<password>

# --- DNS ---
DNS_ZONE=example.com
DNS_RECORDS=api:A,portal:A,monitoring:A
DNS_TTL=300
