# =============================================================================
# Hetzner Test-Fixtures
# =============================================================================
#
# Defaults fuer Integration-Tests gegen die Hetzner Cloud API.
# Credentials gehoeren in .env.local (gitignored).
#

# --- API ---
HETZNER_API_TOKEN=<token>
# DNS-Token (nur noetig wenn DNS in anderem Hetzner-Projekt liegt)
HETZNER_DNS_TOKEN=<token>

# --- Server ---
HETZNER_REGION=nbg1
HETZNER_IMAGE=ubuntu-24.04
SERVER_TYPE=cpx22

# --- Test-Prefix (damit Test-Ressourcen erkennbar sind) ---
TEST_RESOURCE_PREFIX=prov-test

# --- Private Network (Cluster-Tests) ---
PRIVATE_NETWORK_SUBNET=10.0.99.0/24
PRIVATE_NETWORK_ZONE=eu-central

# --- Load Balancer (Cluster-Tests) ---
LOADBALANCER_TYPE=lb11
LOADBALANCER_ALGORITHM=round_robin
LOADBALANCER_HEALTH_CHECK_PROTOCOL=http
LOADBALANCER_HEALTH_CHECK_PORT=80
LOADBALANCER_HEALTH_CHECK_PATH=/health
LOADBALANCER_HEALTH_CHECK_INTERVAL=15
LOADBALANCER_HEALTH_CHECK_TIMEOUT=10
LOADBALANCER_HEALTH_CHECK_RETRIES=3
