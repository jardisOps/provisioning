{
    "name": "jardisops/provisioning",
    "description": "Cloud infrastructure provisioning for PHP applications — multi-provider support for servers, networks, firewalls, DNS, and load balancers",
    "type": "library",
    "license": "MIT",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "authors": [
        {
            "name": "Jardis Development",
            "email": "jardisDev@headgent.com"
        }
    ],
    "require": {
        "php": ">=8.2",
        "jardissupport/dotenv": "^1.0",
        "jardissupport/secret": "^1.0",
        "ext-json": "*",
        "ext-curl": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^2.0.4",
        "squizlabs/php_codesniffer": "^3.11.2"
    },
    "bin": [
        "bin/provision"
    ],
    "autoload": {
        "psr-4": {
            "JardisOps\\Provisioning\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "JardisOps\\Provisioning\\Tests\\": "tests/"
        }
    },
    "homepage": "https://github.com/jardisops/provisioning",
    "support": {
        "issues": "https://github.com/jardisops/provisioning/issues",
        "email": "jardisDev@headgent.com"
    },
    "keywords": [
        "provisioning",
        "cloud",
        "infrastructure",
        "devops",
        "jardis",
        "headgent"
    ]
}
