# =============================================================================
# Provisioning — Hetzner Cloud Provider
# =============================================================================
#
# Kopiere diese Datei nach .env.hetzner in dein Projektverzeichnis.
#

# --- Provisioning ---
PROVISION_MODE=single
INFRA_PROVIDER=hetzner
# DNS_PROVIDER=hetzner

# --- API ---
# HETZNER_API_TOKEN=secret(base64encryptedvalue)
HETZNER_API_TOKEN=<token>
# DNS-Token (nur noetig wenn DNS in anderem Hetzner-Projekt liegt, sonst wird HETZNER_API_TOKEN genutzt)
# HETZNER_DNS_TOKEN=secret(base64encryptedvalue)
HETZNER_REGION=fsn1
HETZNER_IMAGE=ubuntu-24.04
HETZNER_BACKUP_ENABLED=true

# --- SSH ---
SSH_KEY_PATH=~/.ssh/id_ed25519.pub

# --- Server (Single-Modus) ---
SERVER_NAME=headgent-prod
SERVER_TYPE=cpx31
SERVER_IP_TYPE=standard
# VOLUME_SIZE=50

# --- Cluster (Cluster-Modus) ---
# CLUSTER_NAME=headgent
# CLUSTER_NODE_COUNT=3
#
# CLUSTER_NODE_1_ROLE=server
# CLUSTER_NODE_1_TYPE=cpx31
# CLUSTER_NODE_1_NAME=headgent-server-1
# CLUSTER_NODE_1_VOLUME_SIZE=50
#
# CLUSTER_NODE_2_ROLE=agent
# CLUSTER_NODE_2_TYPE=cpx31
# CLUSTER_NODE_2_NAME=headgent-agent-1
#
# CLUSTER_NODE_3_ROLE=agent
# CLUSTER_NODE_3_TYPE=cpx31
# CLUSTER_NODE_3_NAME=headgent-agent-2

# --- Private Network (Cluster-Modus) ---
# PRIVATE_NETWORK_NAME=headgent-net
# PRIVATE_NETWORK_SUBNET=10.0.1.0/24
# PRIVATE_NETWORK_ZONE=eu-central

# --- Load Balancer (Cluster-Modus) ---
# LOADBALANCER_ENABLED=true
# LOADBALANCER_NAME=headgent-lb
# LOADBALANCER_TYPE=lb11
# LOADBALANCER_ALGORITHM=round_robin
# LOADBALANCER_HEALTH_CHECK_PROTOCOL=http
# LOADBALANCER_HEALTH_CHECK_PORT=80
# LOADBALANCER_HEALTH_CHECK_PATH=/health
# LOADBALANCER_HEALTH_CHECK_INTERVAL=15
# LOADBALANCER_HEALTH_CHECK_TIMEOUT=10
# LOADBALANCER_HEALTH_CHECK_RETRIES=3

# --- Placement Group (Cluster-Modus) ---
# PLACEMENT_GROUP_ENABLED=true
# PLACEMENT_GROUP_NAME=headgent-spread
# PLACEMENT_GROUP_TYPE=spread

# --- Security / Cloud-Init (optional, alle haben sinnvolle Defaults) ---
# SECURITY_DEPLOY_USER=deploy
# SECURITY_SSH_PORT=22
# SECURITY_DISABLE_ROOT=true
# SECURITY_DISABLE_PASSWORD_AUTH=true
# SECURITY_AUTO_UPDATES=true
# SECURITY_FAIL2BAN=true

# --- Firewall (optional) ---
# FIREWALL_EXTERNAL_PORTS_TCP=22,80,443

# --- TLS Certificate (Cluster-Modus, Managed Let's Encrypt via Hetzner) ---
# Domains werden automatisch aus DNS_RECORDS + DNS_ZONE abgeleitet.
# Bestehendes gueltiges Zertifikat wird wiederverwendet, kein Neuerstellen noetig.
# Hetzner erneuert automatisch solange das Cert einem LB zugewiesen ist.
# CERTIFICATE_CLEANUP=false

# --- DNS (optional, nur wenn DNS_PROVIDER gesetzt) ---
# DNS_ZONE=example.com
# DNS_RECORDS=api:A,portal:A
# DNS_TTL=300
